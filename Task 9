import java.util.Scanner;
public class Main {
    public static int count(String s, int i) {
        if (i == s.length())
            return 0;
        return 1 + count(s, i + 1);
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String s = sc.next();
        System.out.println(count(s, 0));
    }
}